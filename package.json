		"check": "biome check .",
		"check:fix": "biome check --write .",
		"new": "tsx scripts/new-post.ts",
		"update-theme": "tsx scripts/update-theme.ts"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.5.0",
		"@astrojs/mdx": "^5.0.4",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@lucide/astro": "^1.14.0",
		"@mathjax/src": "^4.1.2",
		"@playform/inline": "^0.1.4",
		"@sentry/astro": "^10.52.0",
		"@sentry/cloudflare": "^10.52.0",
		"@shikijs/twoslash": "^4.0.2",
		"astro": "^6.3.1",
		"astro-pagefind": "^2.0.0",
		"feed": "^5.2.1",
		"hast-util-to-text": "^4.0.2",
		"hastscript": "^9.0.1",
		"markdown-it": "^14.1.1",
		"mdast-util-to-string": "^4.0.0",
		"mermaid": "^11.15.0",
		"node-html-parser": "^7.1.0",
		"puppeteer": "^24.43.1",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"remark-directive": "^4.0.0",
		"remark-math": "^6.0.0",
		"remark-smartypants": "^3.0.2",
		"sanitize-html": "^2.17.3",
		"satori": "^0.26.0",
		"sharp": "^0.34.5",
		"twoslash": "^0.3.8",
		"unist-util-visit": "^5.1.0",
		"unist-util-visit-parents": "^6.0.2"
	},
	"pnpm": {
		"overrides": {
			"sharp": "^0.34.5",
			"wrangler": "^4.90.0"
		},
		"onlyBuiltDependencies": [
			"@sentry/cli",
			"esbuild",
			"lefthook",
			"puppeteer",
			"sharp",
			"workerd"
