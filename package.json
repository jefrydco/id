{
	"name": "jefrydco-id",
	"type": "module",
	"version": "1.0.0",
	"license": "MIT",
	"scripts": {
		"dev": "astro dev",
		"prebuild": "pnpm exec tsx scripts/toggle-proxy.ts",
		"build": "pnpm run prebuild && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "biome format --write .",
