				"@astrojs/cloudflare>astro": "^6.0.0"
			}
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@shikijs/transformers": "^4.0.2",
		"@types/markdown-it": "^14.1.2",
		"@types/sanitize-html": "^2.16.1",
		"@vite-pwa/assets-generator": "^1.0.2",
		"@vite-pwa/astro": "^1.2.0",
		"lefthook": "^2.1.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"workbox-window": "^7.4.1"
